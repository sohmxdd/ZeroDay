# AEGIS — Environment Configuration
# Copy this file to .env and fill in your keys

# Gemini API Key (Required for LLM reasoning)
GEMINI_API_KEY=your_gemini_api_key_here

# Pipeline Configuration (Optional)
AEGIS_ALPHA=0.6
AEGIS_BETA=0.4
AEGIS_MODE=full_pipeline
AEGIS_MODEL_TYPE=logistic_regression
AEGIS_GEMINI_ENABLED=true
AEGIS_GEMINI_MODEL=gemini-2.5-flash
